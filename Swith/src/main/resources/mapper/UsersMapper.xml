<!-- MembersMapper (myBatis) -->

<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTO Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kh.mapper.MembersMapper">
	<!-- 회원등록 -->
	<insert id ="insertUser" parameterType="lm.swith.user.model.User">
		INSERT INTO USERS (USER_NO,USER_ID,USER_PASSWORD,USER_NAME,USER_NICKNAME,USER_PROFILE,USER_ADDRESS,USER_INTRODUCTION,USER_ROLE)
		VALUES(users_seq.NEXTVAL, #{userID},#{password},#{userName},#{userNickname},#{userProfile},#{userAddress},#{userAddress},#{userIntroduction},#{role})
	</insert>
	
	<select id ="loginUser" parameterType="lm.swith.user.model.User">
	SELECT * FROM Users WHERE USER_ID = #{userID} AND USER_PASSWORD = #{password}
	</select>
	
	<select id = "findUserRole" parameterType="lm.swiith.user.model.User">
		SELECT * FROM Users WHERE ROLE = #{role}
	</select>
</mapper>